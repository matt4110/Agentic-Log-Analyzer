-a always,exit -F arch=b32 -F path=/bin/nc.traditional -F perm=x -k susp_activity

## Sbin suspicious activity
-a always,exit -F arch=b64 -F path=/sbin/iptables -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/sbin/iptables -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/sbin/ip6tables -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/sbin/ip6tables -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/sbin/ifconfig -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/sbin/ifconfig -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/usr/sbin/arptables -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/usr/sbin/arptables -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/usr/sbin/ebtables -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/usr/sbin/ebtables -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/sbin/xtables-nft-multi -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/sbin/xtables-nft-multi -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/usr/sbin/nft -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/usr/sbin/nft -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/usr/sbin/tcpdump -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/usr/sbin/tcpdump -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/usr/sbin/traceroute -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/usr/sbin/traceroute -F perm=x -k sbin_susp
-a always,exit -F arch=b64 -F path=/usr/sbin/ufw -F perm=x -k sbin_susp
-a always,exit -F arch=b32 -F path=/usr/sbin/ufw -F perm=x -k sbin_susp

## Suspicious shells
-a always,exit -F arch=b64 -F path=/bin/ash -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/ash -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/bin/csh -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/csh -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/bin/fish -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/fish -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/bin/tcsh -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/tcsh -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/bin/tclsh -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/tclsh -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/bin/xonsh -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/xonsh -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/usr/local/bin/xonsh -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/usr/local/bin/xonsh -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/bin/open -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/open -F perm=x -k susp_shell
-a always,exit -F arch=b64 -F path=/bin/rbash -F perm=x -k susp_shell
-a always,exit -F arch=b32 -F path=/bin/rbash -F perm=x -k susp_shell

## Web Server Activity
## Change the number "33" to the ID of your WebServer user. Default: www-data:x:33:33
-a always,exit -F arch=b64 -S execve -F euid=33 -k detect_execve_www
-a always,exit -F arch=b64 -S open -S openat -S creat -F euid=33 -F exit!=-ENOENT -k www_file_write
-a always,exit -F arch=b64 -S socket -F euid=33 -F a0=2 -k www_socket_created
-a always,exit -F arch=b64 -S socket -F euid=33 -F a0=10 -k www_socket_created

## Shell/profile configurations
-a always,exit -F arch=b64 -F dir=/etc/profile.d/ -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F dir=/etc/profile.d/ -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -F path=/etc/profile -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F path=/etc/profile -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -F path=/etc/shells -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F path=/etc/shells -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -F path=/etc/bashrc -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F path=/etc/bashrc -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -F path=/etc/csh.cshrc -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F path=/etc/csh.cshrc -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -F path=/etc/csh.login -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F path=/etc/csh.login -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -F dir=/etc/fish/ -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F dir=/etc/fish/ -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -F dir=/etc/zsh/ -F perm=wa -k shell_profiles
-a always,exit -F arch=b32 -F dir=/etc/zsh/ -F perm=wa -k shell_profiles

## Injection
### These rules watch for code injection by the ptrace facility.
### This could indicate someone trying to do something bad or just debugging
-a always,exit -F arch=b64 -S ptrace -F a0=0x4 -k code_injection
-a always,exit -F arch=b64 -S ptrace -F a0=0x5 -k data_injection
-a always,exit -F arch=b64 -S ptrace -F a0=0x6 -k register_injection
-a always,exit -F arch=b64 -S ptrace -k tracing

## Privilege Abuse
### The purpose of this rule is to detect when an admin may be abusing power by looking in user's home dir.
-a always,exit -F dir=/home -F uid=0 -F auid>=1000 -F auid!=-1 -C auid!=obj_uid -k power_abuse

# Socket Creations
## Scoped to auid>=1000 AND auid!=-1 to correctly exclude daemon/system processes.
## Note: auid=4294967295 (unset) satisfies auid>=1000 due to unsigned wraparound,
## so auid!=-1 is required to prevent system processes from matching.
-a always,exit -F arch=b32 -S socket -F a0=2  -F auid>=1000 -F auid!=-1 -k network_socket_created
-a always,exit -F arch=b64 -S socket -F a0=2  -F auid>=1000 -F auid!=-1 -k network_socket_created
-a always,exit -F arch=b32 -S socket -F a0=10 -F auid>=1000 -F auid!=-1 -k network_socket_created
-a always,exit -F arch=b64 -S socket -F a0=10 -F auid>=1000 -F auid!=-1 -k network_socket_created

## Root command executions
-a always,exit -F arch=b64 -F euid=0 -F auid>=1000 -F auid!=-1 -S execve -k rootcmd
-a always,exit -F arch=b32 -F euid=0 -F auid>=1000 -F auid!=-1 -S execve -k rootcmd

## File Deletion Events by User
-a always,exit -F arch=b64 -S rmdir -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=-1 -k delete
-a always,exit -F arch=b32 -S rmdir -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=-1 -k delete

## File Access
### Unauthorized Access (unsuccessful)
-a always,exit -F arch=b64 -S creat -S open -S openat -S open_by_handle_at -S truncate -S ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=-1 -k file_access
-a always,exit -F arch=b64 -S creat -S open -S openat -S open_by_handle_at -S truncate -S ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=-1 -k file_access
-a always,exit -F arch=b32 -S creat -S open -S openat -S truncate -S ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=-1 -k file_access
-a always,exit -F arch=b32 -S creat -S open -S openat -S truncate -S ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=-1 -k file_access
