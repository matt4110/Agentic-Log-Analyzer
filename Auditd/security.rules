# Auditd Rules
# Revised: converted old-style -w watch rules to modern -a always,exit form
# (eliminates "Old style watch rules are slower" warnings)
# Revised: added -F arch= to all perm= filters
# (eliminates "perm used without an arch is slower" warnings)
# Revised: socket rules now include -F auid!=-1 to correctly exclude
# daemon processes whose auid=4294967295 (unset) would otherwise
# incorrectly satisfy auid>=1000 due to unsigned integer wraparound

# Ignore errors
## e.g. caused by users or files not found in the local environment
-i

# Self Auditing ---------------------------------------------------------------

## Audit the audit logs
### Successful and unsuccessful attempts to read information from the audit records
-a always,exit -F arch=b64 -F dir=/var/log/audit/ -F perm=wra -k auditlog
-a always,exit -F arch=b32 -F dir=/var/log/audit/ -F perm=wra -k auditlog
-a always,exit -F arch=b64 -F dir=/var/audit/ -F perm=wra -k auditlog
-a always,exit -F arch=b32 -F dir=/var/audit/ -F perm=wra -k auditlog

## Auditd configuration
### Modifications to audit configuration that occur while the audit collection functions are operating
-a always,exit -F arch=b64 -F dir=/etc/audit/ -F perm=wa -k auditconfig
-a always,exit -F arch=b32 -F dir=/etc/audit/ -F perm=wa -k auditconfig
-a always,exit -F arch=b64 -F path=/etc/libaudit.conf -F perm=wa -k auditconfig
-a always,exit -F arch=b32 -F path=/etc/libaudit.conf -F perm=wa -k auditconfig
-a always,exit -F arch=b64 -F dir=/etc/audisp/ -F perm=wa -k audispconfig
-a always,exit -F arch=b32 -F dir=/etc/audisp/ -F perm=wa -k audispconfig

## Monitor for use of audit management tools
-a always,exit -F arch=b64 -F path=/sbin/auditctl -F perm=x -k audittools
-a always,exit -F arch=b32 -F path=/sbin/auditctl -F perm=x -k audittools
-a always,exit -F arch=b64 -F path=/sbin/auditd -F perm=x -k audittools
-a always,exit -F arch=b32 -F path=/sbin/auditd -F perm=x -k audittools
-a always,exit -F arch=b64 -F path=/usr/sbin/auditd -F perm=x -k audittools
-a always,exit -F arch=b32 -F path=/usr/sbin/auditd -F perm=x -k audittools
-a always,exit -F arch=b64 -F path=/usr/sbin/augenrules -F perm=x -k audittools
-a always,exit -F arch=b32 -F path=/usr/sbin/augenrules -F perm=x -k audittools

## Access to all audit trails
-a always,exit -F path=/usr/sbin/ausearch -F perm=x -F arch=b64 -k audittools
-a always,exit -F path=/usr/sbin/aureport -F perm=x -F arch=b64 -k audittools
-a always,exit -F path=/usr/sbin/aulast -F perm=x -F arch=b64 -k audittools
-a always,exit -F path=/usr/sbin/aulastlogin -F perm=x -F arch=b64 -k audittools
-a always,exit -F path=/usr/sbin/auvirt -F perm=x -F arch=b64 -k audittools

# Filters ---------------------------------------------------------------------

### We put these early because audit is a first match wins system.

## Exclude noisy crypto key events on public-facing servers
-a always,exclude -F msgtype=CRYPTO_KEY_USER

## High Volume Event Filter
-a never,exit -F arch=b32 -F dir=/dev/shm/ -k sharedmemaccess
-a never,exit -F arch=b64 -F dir=/dev/shm/ -k sharedmemaccess
-a never,exit -F arch=b64 -F path=/sbin/auditctl -F perm=x

## Suppress internal sshd privsep connect noise
## sshd-session and sshd-auth make connect() calls before auth, auid is always unset
## These are internal IPC/loopback connects, not real outbound connections
-a never,exit -F arch=b64 -S connect -F exe=/usr/lib/openssh/sshd-session
-a never,exit -F arch=b64 -S connect -F exe=/usr/lib/openssh/sshd-auth

# Rules -----------------------------------------------------------------------

## Kernel parameters
-a always,exit -F arch=b64 -F path=/etc/sysctl.conf -F perm=wa -k sysctl
-a always,exit -F arch=b32 -F path=/etc/sysctl.conf -F perm=wa -k sysctl
-a always,exit -F arch=b64 -F dir=/etc/sysctl.d -F perm=wa -k sysctl
-a always,exit -F arch=b32 -F dir=/etc/sysctl.d -F perm=wa -k sysctl

## Kernel module loading and unloading
-a always,exit -F arch=b64 -F path=/sbin/insmod -F perm=x -F auid!=-1 -k kernel_modules
-a always,exit -F arch=b32 -F path=/sbin/insmod -F perm=x -F auid!=-1 -k kernel_modules
-a always,exit -F arch=b64 -F path=/sbin/modprobe -F perm=x -F auid!=-1 -k kernel_modules
-a always,exit -F arch=b32 -F path=/sbin/modprobe -F perm=x -F auid!=-1 -k kernel_modules
-a always,exit -F arch=b64 -F path=/sbin/rmmod -F perm=x -F auid!=-1 -k kernel_modules
-a always,exit -F arch=b32 -F path=/sbin/rmmod -F perm=x -F auid!=-1 -k kernel_modules
-a always,exit -F arch=b64 -S finit_module -S init_module -S delete_module -F auid!=-1 -k kernel_modules
-a always,exit -F arch=b32 -S finit_module -S init_module -S delete_module -F auid!=-1 -k kernel_modules

## Mount operations (only attributable)
-a always,exit -F arch=b64 -S mount -S umount2 -F auid!=-1 -k mount
-a always,exit -F arch=b32 -S mount -S umount2 -F auid!=-1 -k mount

## Cron configuration & scheduled jobs
-a always,exit -F arch=b64 -F path=/etc/cron.allow -F perm=wa -k cron
-a always,exit -F arch=b32 -F path=/etc/cron.allow -F perm=wa -k cron
-a always,exit -F arch=b64 -F path=/etc/cron.deny -F perm=wa -k cron
-a always,exit -F arch=b32 -F path=/etc/cron.deny -F perm=wa -k cron
-a always,exit -F arch=b64 -F dir=/etc/cron.d/ -F perm=wa -k cron
-a always,exit -F arch=b32 -F dir=/etc/cron.d/ -F perm=wa -k cron
-a always,exit -F arch=b64 -F dir=/etc/cron.daily/ -F perm=wa -k cron
-a always,exit -F arch=b32 -F dir=/etc/cron.daily/ -F perm=wa -k cron
-a always,exit -F arch=b64 -F dir=/etc/cron.hourly/ -F perm=wa -k cron
-a always,exit -F arch=b32 -F dir=/etc/cron.hourly/ -F perm=wa -k cron
-a always,exit -F arch=b64 -F dir=/etc/cron.monthly/ -F perm=wa -k cron
-a always,exit -F arch=b32 -F dir=/etc/cron.monthly/ -F perm=wa -k cron
-a always,exit -F arch=b64 -F dir=/etc/cron.weekly/ -F perm=wa -k cron
-a always,exit -F arch=b32 -F dir=/etc/cron.weekly/ -F perm=wa -k cron
-a always,exit -F arch=b64 -F path=/etc/crontab -F perm=wa -k cron
-a always,exit -F arch=b32 -F path=/etc/crontab -F perm=wa -k cron
-a always,exit -F arch=b64 -F dir=/var/spool/cron/ -F perm=wa -k cron
-a always,exit -F arch=b32 -F dir=/var/spool/cron/ -F perm=wa -k cron

## User, group, password databases
-a always,exit -F arch=b64 -F path=/etc/group -F perm=wa -k etcgroup
-a always,exit -F arch=b32 -F path=/etc/group -F perm=wa -k etcgroup
-a always,exit -F arch=b64 -F path=/etc/passwd -F perm=wa -k etcpasswd
-a always,exit -F arch=b32 -F path=/etc/passwd -F perm=wa -k etcpasswd
-a always,exit -F arch=b64 -F path=/etc/gshadow -F perm=wa -k etcgroup
-a always,exit -F arch=b32 -F path=/etc/gshadow -F perm=wa -k etcgroup
-a always,exit -F arch=b64 -F path=/etc/shadow -F perm=wa -k etcpasswd
-a always,exit -F arch=b32 -F path=/etc/shadow -F perm=wa -k etcpasswd
-a always,exit -F arch=b64 -F path=/etc/security/opasswd -F perm=wa -k opasswd
-a always,exit -F arch=b32 -F path=/etc/security/opasswd -F perm=wa -k opasswd

## Sudoers file changes
-a always,exit -F arch=b64 -F path=/etc/sudoers -F perm=wa -k sudoers
-a always,exit -F arch=b32 -F path=/etc/sudoers -F perm=wa -k sudoers
-a always,exit -F arch=b64 -F dir=/etc/sudoers.d/ -F perm=wa -k sudoers
-a always,exit -F arch=b32 -F dir=/etc/sudoers.d/ -F perm=wa -k sudoers

## Passwd
-a always,exit -F arch=b64 -F path=/usr/bin/passwd -F perm=x -k passwd_modification
-a always,exit -F arch=b32 -F path=/usr/bin/passwd -F perm=x -k passwd_modification

## Tools to change group identifiers
-a always,exit -F arch=b64 -F path=/usr/sbin/groupadd -F perm=x -k group_modification
-a always,exit -F arch=b32 -F path=/usr/sbin/groupadd -F perm=x -k group_modification
-a always,exit -F arch=b64 -F path=/usr/sbin/groupmod -F perm=x -k group_modification
-a always,exit -F arch=b32 -F path=/usr/sbin/groupmod -F perm=x -k group_modification
-a always,exit -F arch=b64 -F path=/usr/sbin/addgroup -F perm=x -k group_modification
-a always,exit -F arch=b32 -F path=/usr/sbin/addgroup -F perm=x -k group_modification
-a always,exit -F arch=b64 -F path=/usr/sbin/useradd -F perm=x -k user_modification
-a always,exit -F arch=b32 -F path=/usr/sbin/useradd -F perm=x -k user_modification
-a always,exit -F arch=b64 -F path=/usr/sbin/userdel -F perm=x -k user_modification
-a always,exit -F arch=b32 -F path=/usr/sbin/userdel -F perm=x -k user_modification
-a always,exit -F arch=b64 -F path=/usr/sbin/usermod -F perm=x -k user_modification
-a always,exit -F arch=b32 -F path=/usr/sbin/usermod -F perm=x -k user_modification
-a always,exit -F arch=b64 -F path=/usr/sbin/adduser -F perm=x -k user_modification
-a always,exit -F arch=b32 -F path=/usr/sbin/adduser -F perm=x -k user_modification

## Login configuration and information
-a always,exit -F arch=b64 -F path=/etc/login.defs -F perm=wa -k login_config
-a always,exit -F arch=b32 -F path=/etc/login.defs -F perm=wa -k login_config
-a always,exit -F arch=b64 -F path=/etc/securetty -F perm=wa -k login_config
-a always,exit -F arch=b32 -F path=/etc/securetty -F perm=wa -k login_config
-a always,exit -F arch=b64 -F path=/var/log/faillog -F perm=wa -k login_config
-a always,exit -F arch=b32 -F path=/var/log/faillog -F perm=wa -k login_config
-a always,exit -F arch=b64 -F path=/var/log/lastlog -F perm=wa -k login_config
-a always,exit -F arch=b32 -F path=/var/log/lastlog -F perm=wa -k login_config
-a always,exit -F arch=b64 -F path=/var/log/tallylog -F perm=wa -k login_config
-a always,exit -F arch=b32 -F path=/var/log/tallylog -F perm=wa -k login_config

## Network Environment
### Changes to hostname
-a always,exit -F arch=b64 -S sethostname -S setdomainname -k network_modifications
-a always,exit -F arch=b32 -S sethostname -S setdomainname -k network_modifications

### Detect Remote Shell Use
### Covers common shells - extend if users have non-standard login shells
-a always,exit -F arch=b64 -F exe=/bin/bash -F success=1 -S connect -k remote_shell
-a always,exit -F arch=b64 -F exe=/usr/bin/bash -F success=1 -S connect -k remote_shell
-a always,exit -F arch=b64 -F exe=/bin/zsh -F success=1 -S connect -k remote_shell
-a always,exit -F arch=b64 -F exe=/usr/bin/zsh -F success=1 -S connect -k remote_shell
-a always,exit -F arch=b64 -F exe=/bin/dash -F success=1 -S connect -k remote_shell

### Successful IPv4 Connections
-a always,exit -F arch=b64 -S connect -F a2=16 -F success=1 -F key=network_connect_4

### Successful IPv6 Connections
-a always,exit -F arch=b64 -S connect -F a2=28 -F success=1 -F key=network_connect_6

### Changes to other files
-a always,exit -F arch=b64 -F path=/etc/hosts -F perm=wa -k network_modifications
-a always,exit -F arch=b32 -F path=/etc/hosts -F perm=wa -k network_modifications
-a always,exit -F arch=b64 -F path=/etc/sysconfig/network -F perm=wa -k network_modifications
-a always,exit -F arch=b32 -F path=/etc/sysconfig/network -F perm=wa -k network_modifications
-a always,exit -F arch=b64 -F dir=/etc/sysconfig/network-scripts -F perm=wa -k network_modifications
-a always,exit -F arch=b32 -F dir=/etc/sysconfig/network-scripts -F perm=wa -k network_modifications
-a always,exit -F arch=b64 -F dir=/etc/network/ -F perm=wa -k network_modifications
-a always,exit -F arch=b32 -F dir=/etc/network/ -F perm=wa -k network_modifications
-a always,exit -F arch=b64 -F dir=/etc/NetworkManager/ -F perm=wa -k network_modifications
-a always,exit -F arch=b32 -F dir=/etc/NetworkManager/ -F perm=wa -k network_modifications

## System startup scripts
-a always,exit -F arch=b64 -F path=/etc/inittab -F perm=wa -k startup_scripts
-a always,exit -F arch=b32 -F path=/etc/inittab -F perm=wa -k startup_scripts
-a always,exit -F arch=b64 -F dir=/etc/init.d/ -F perm=wa -k startup_scripts
-a always,exit -F arch=b32 -F dir=/etc/init.d/ -F perm=wa -k startup_scripts
-a always,exit -F arch=b64 -F dir=/etc/init/ -F perm=wa -k startup_scripts
-a always,exit -F arch=b32 -F dir=/etc/init/ -F perm=wa -k startup_scripts

## Pam configuration
-a always,exit -F arch=b64 -F dir=/etc/pam.d/ -F perm=wa -k pam
-a always,exit -F arch=b32 -F dir=/etc/pam.d/ -F perm=wa -k pam
-a always,exit -F arch=b64 -F path=/etc/security/limits.conf -F perm=wa -k pam
-a always,exit -F arch=b32 -F path=/etc/security/limits.conf -F perm=wa -k pam
-a always,exit -F arch=b64 -F dir=/etc/security/limits.d -F perm=wa -k pam
-a always,exit -F arch=b32 -F dir=/etc/security/limits.d -F perm=wa -k pam
-a always,exit -F arch=b64 -F path=/etc/security/pam_env.conf -F perm=wa -k pam
-a always,exit -F arch=b32 -F path=/etc/security/pam_env.conf -F perm=wa -k pam
-a always,exit -F arch=b64 -F path=/etc/security/namespace.conf -F perm=wa -k pam
-a always,exit -F arch=b32 -F path=/etc/security/namespace.conf -F perm=wa -k pam
-a always,exit -F arch=b64 -F dir=/etc/security/namespace.d -F perm=wa -k pam
-a always,exit -F arch=b32 -F dir=/etc/security/namespace.d -F perm=wa -k pam
-a always,exit -F arch=b64 -F path=/etc/security/namespace.init -F perm=wa -k pam
-a always,exit -F arch=b32 -F path=/etc/security/namespace.init -F perm=wa -k pam

## SSH configuration
-a always,exit -F arch=b64 -F path=/etc/ssh/sshd_config -F perm=wa -k ssh_config
-a always,exit -F arch=b32 -F path=/etc/ssh/sshd_config -F perm=wa -k ssh_config
-a always,exit -F arch=b64 -F dir=/etc/ssh/sshd_config.d -F perm=wa -k ssh_config
-a always,exit -F arch=b32 -F dir=/etc/ssh/sshd_config.d -F perm=wa -k ssh_config

## root ssh key tampering
-a always,exit -F arch=b64 -F dir=/root/.ssh -F perm=wa -k rootkey
-a always,exit -F arch=b32 -F dir=/root/.ssh -F perm=wa -k rootkey

## Systemd
-a always,exit -F arch=b64 -F path=/bin/systemctl -F perm=x -k systemd
-a always,exit -F arch=b32 -F path=/bin/systemctl -F perm=x -k systemd
-a always,exit -F arch=b64 -F dir=/etc/systemd/ -F perm=wa -k systemd
-a always,exit -F arch=b32 -F dir=/etc/systemd/ -F perm=wa -k systemd
-a always,exit -F arch=b64 -F dir=/usr/lib/systemd -F perm=wa -k systemd
-a always,exit -F arch=b32 -F dir=/usr/lib/systemd -F perm=wa -k systemd

## Critical elements access failures
-a always,exit -F arch=b64 -S open -F dir=/etc -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S open -F dir=/bin -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S open -F dir=/sbin -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S open -F dir=/usr/bin -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S open -F dir=/usr/sbin -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S open -F dir=/var -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S open -F dir=/home -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S open -F dir=/srv -F success=0 -k unauthedfileaccess

## Process ID change (switching accounts) applications
-a always,exit -F arch=b64 -F path=/bin/su -F perm=x -k priv_esc
-a always,exit -F arch=b32 -F path=/bin/su -F perm=x -k priv_esc
-a always,exit -F arch=b64 -F path=/usr/bin/sudo -F perm=x -k priv_esc
-a always,exit -F arch=b32 -F path=/usr/bin/sudo -F perm=x -k priv_esc

## Power state
-a always,exit -F arch=b64 -F path=/sbin/shutdown -F perm=x -k power
-a always,exit -F arch=b32 -F path=/sbin/shutdown -F perm=x -k power
-a always,exit -F arch=b64 -F path=/sbin/poweroff -F perm=x -k power
-a always,exit -F arch=b32 -F path=/sbin/poweroff -F perm=x -k power
-a always,exit -F arch=b64 -F path=/sbin/reboot -F perm=x -k power
-a always,exit -F arch=b32 -F path=/sbin/reboot -F perm=x -k power
-a always,exit -F arch=b64 -F path=/sbin/halt -F perm=x -k power
-a always,exit -F arch=b32 -F path=/sbin/halt -F perm=x -k power

## Discretionary Access Control (DAC) modifications
-a always,exit -F arch=b64 -S chmod -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S chown -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S fchmod -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S fchmodat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S fchown -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S fchownat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S fremovexattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S fsetxattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S lchown -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S lremovexattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S lsetxattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S removexattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S setxattr -F auid>=1000 -F auid!=-1 -k perm_mod
## b32 equivalents for DAC modifications
-a always,exit -F arch=b32 -S chmod -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S chown -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S fchmod -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S fchmodat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S fchown -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S fchownat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S fremovexattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S fsetxattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S lchown -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S lremovexattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S lsetxattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S removexattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S setxattr -F auid>=1000 -F auid!=-1 -k perm_mod

# Special Rules ---------------------------------------------------------------

## Reconnaissance
-a always,exit -F arch=b64 -F path=/usr/bin/whoami -F perm=x -k recon
-a always,exit -F arch=b32 -F path=/usr/bin/whoami -F perm=x -k recon
-a always,exit -F arch=b64 -F path=/usr/bin/id -F perm=x -k recon
-a always,exit -F arch=b32 -F path=/usr/bin/id -F perm=x -k recon
-a always,exit -F arch=b64 -F path=/bin/hostname -F perm=x -k recon
-a always,exit -F arch=b32 -F path=/bin/hostname -F perm=x -k recon
-a always,exit -F arch=b64 -F path=/bin/uname -F perm=x -k recon
-a always,exit -F arch=b32 -F path=/bin/uname -F perm=x -k recon
## Changed from -p r to -p wa: read watches on these files are extremely noisy
## and triggered by many normal processes including auditctl itself
-a always,exit -F arch=b64 -F path=/etc/issue -F perm=wa -k recon
-a always,exit -F arch=b32 -F path=/etc/issue -F perm=wa -k recon
-a always,exit -F arch=b64 -F path=/etc/hostname -F perm=wa -k recon
-a always,exit -F arch=b32 -F path=/etc/hostname -F perm=wa -k recon

## Suspicious activity
-a always,exit -F arch=b64 -F path=/usr/bin/wget -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/wget -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/usr/bin/curl -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/curl -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/usr/bin/base64 -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/base64 -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/bin/nc -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/bin/nc -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/bin/netcat -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/bin/netcat -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/usr/bin/ncat -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/ncat -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/usr/bin/ss -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/ss -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/usr/bin/netstat -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/netstat -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/usr/bin/ssh -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/ssh -F perm=x -k susp_activity
-a always,exit -F arch=b64 -F path=/usr/bin/scp -F perm=x -k susp_activity
-a always,exit -F arch=b32 -F path=/usr/bin/scp -F perm=x -k susp_activity
